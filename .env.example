# ─── fig2el Environment Variables ───────────────────────────
# Copy to .env.local pour le dev, ou ajouter dans Vercel Dashboard

# Votre token Figma Personal Access Token
# Obtenez-le sur : https://www.figma.com/developers/api#authentication
FIGMA_TOKEN=figd_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optionnel : restreindre les origines CORS (laisser vide = tout autoriser)
# ALLOWED_ORIGIN=https://votre-domaine.vercel.app